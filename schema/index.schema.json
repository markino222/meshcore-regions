{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/marcelverdult/meshcore-regions/schema/index.schema.json",
  "title": "Index",
  "type": "object",
  "required": ["generated_at", "tree", "flat"],
  "additionalProperties": false,
  "properties": {
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "tree": {
      "type": "array",
      "items": { "$ref": "region.schema.json" }
    },
    "flat": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "name"],
        "additionalProperties": false,
        "properties": {
          "path": {
            "type": "string",
            "pattern": "^[a-z0-9]{1,29}(-[a-z0-9]{1,29})*$"
          },
          "name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 200
          }
        }
      }
    }
  }
}
